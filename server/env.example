# server/.env
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามต้องการ

# Port ที่ server จะ listen
PORT=3000

# JWT Secret — เปลี่ยนให้เป็นค่าที่ random และยาว!
JWT_SECRET=your-super-secret-key-change-me-in-production

# JWT Token หมดอายุใน (เช่น 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# CORS — ระบุ origin ที่อนุญาต (ใช้ * สำหรับทุก origin)
CORS_ORIGIN=*

# Database path (default: ./lab-inventory.db)
# DB_PATH=./lab-inventory.db
